APP_NAME=One-Person Company Control Plane
APP_ENV=development
API_PREFIX=/api/v1
DEFAULT_COMPANY_ID=default
STATE_STORE_BACKEND=postgres

POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/multi_agent_company
REDIS_URL=redis://redis:6379/0
VECTOR_DB_URL=http://qdrant:6333
OBJECT_STORE_ENDPOINT=http://minio:9000
OBJECT_STORE_ACCESS_KEY=minioadmin
OBJECT_STORE_SECRET_KEY=minioadmin
FEISHU_BOT_APPS_JSON=[{"employee_id":"chief-of-staff","app_id":"cli_xxx","app_secret":"xxx","bot_identity":"feishu-chief-of-staff","bot_open_id":"ou_xxx","display_name":"OPC - Chief of Staff"},{"employee_id":"product-lead","app_id":"cli_xxx","app_secret":"xxx","bot_identity":"feishu-product-lead","bot_open_id":"ou_xxx","display_name":"OPC - Product Lead"},{"employee_id":"research-lead","app_id":"cli_xxx","app_secret":"xxx","bot_identity":"feishu-research-lead","bot_open_id":"ou_xxx","display_name":"OPC - Research Lead"},{"employee_id":"delivery-lead","app_id":"cli_xxx","app_secret":"xxx","bot_identity":"feishu-delivery-lead","bot_open_id":"ou_xxx","display_name":"OPC - Project Lead"},{"employee_id":"design-lead","app_id":"cli_xxx","app_secret":"xxx","bot_identity":"feishu-design-lead","bot_open_id":"ou_xxx","display_name":"OPC - Design Lead"},{"employee_id":"engineering-lead","app_id":"cli_xxx","app_secret":"xxx","bot_identity":"feishu-engineering-lead","bot_open_id":"ou_xxx","display_name":"OPC - Engineering Lead"},{"employee_id":"quality-lead","app_id":"cli_xxx","app_secret":"xxx","bot_identity":"feishu-quality-lead","bot_open_id":"ou_xxx","display_name":"OPC - Quality Lead"}]
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_SEND_MAX_ATTEMPTS=3
FEISHU_SEND_RETRY_BACKOFF_SECONDS=0.4
FEISHU_VISIBLE_HANDOFF_TURN_LIMIT=20
OPENCLAW_BAILIAN_API_KEY=
OPENCLAW_RUNTIME_MODE=gateway
OPENCLAW_GATEWAY_BASE_URL=http://openclaw-gateway:18789
OPENCLAW_GATEWAY_TOKEN=dev-openclaw-token
OPENCLAW_GATEWAY_API_KEY=
OPENCLAW_GATEWAY_TIMEOUT_SECONDS=25
OPENCLAW_RUNTIME_HOME=.runtime/openclaw/home
OPENCLAW_GATEWAY_HOST_PORT=18789
OPENCLAW_VISIBLE_FOLLOW_UP_LIMIT=3
OPENCLAW_CONTROL_UI_AUTO_PAIR_LOCAL=true
OPENCLAW_GATEWAY_IMAGE=ghcr.io/openclaw/openclaw:2026.3.7
